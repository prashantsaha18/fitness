# .streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .streamlit/secrets.toml and fill in values.
# On Streamlit Cloud: paste contents in App Settings → Secrets.
# NEVER commit secrets.toml to git (it's in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

[database]
url = "postgresql+asyncpg://user:password@host/dbname?ssl=require"

[redis]
url = "redis://localhost:6379/0"

[qdrant]
host    = "localhost"
port    = 6333
api_key = ""

[auth]
jwt_secret = "replace-with-64-char-hex"

[kaggle]
username = ""
key      = ""
