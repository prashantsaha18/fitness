{
  "title": "Fitness Rec Engine — Production Dashboard",
  "uid": "fitness-rec-engine-v1",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["recommendation", "ml", "fitness", "production"],
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": { "type": "prometheus" },
        "expr": "changes(recommendation_requests_total[1m]) > 0",
        "step": "60s",
        "titleFormat": "Deploy",
        "iconColor": "blue"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(recommendation_requests_total, instance)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "🟢 Current RPS",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(recommendation_requests_total{instance=~\"$instance\"}[1m]))",
        "legendFormat": "RPS"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 4000 },
              { "color": "red", "value": 5500 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "⚡ P99 Latency",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(recommendation_latency_ms_bucket[5m])) by (le))",
        "legendFormat": "P99"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "red", "value": 35 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "✅ Success Rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(recommendation_requests_total{status='success'}[5m])) / sum(rate(recommendation_requests_total[5m])) * 100",
        "legendFormat": "Success %"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 98 },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "🔁 Fallback Rate",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(recommendation_fallback_total[5m])) / sum(rate(recommendation_requests_total[5m])) * 100",
        "legendFormat": "Fallback %"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "🧠 ONNX P99",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(onnx_inference_latency_ms_bucket[5m])) by (le))",
        "legendFormat": "ONNX P99"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8 },
              { "color": "red", "value": 12 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "🔍 Qdrant P99",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(qdrant_search_latency_ms_bucket[5m])) by (le))",
        "legendFormat": "ANN P99"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "📈 Latency Percentiles Over Time",
      "description": "P50/P95/P99/P999 end-to-end recommendation latency. SLA: P99 < 35ms.",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(recommendation_latency_ms_bucket[2m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(recommendation_latency_ms_bucket[2m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(recommendation_latency_ms_bucket[2m])) by (le))",
          "legendFormat": "P99"
        },
        {
          "expr": "histogram_quantile(0.999, sum(rate(recommendation_latency_ms_bucket[2m])) by (le))",
          "legendFormat": "P999"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P99" },
            "properties": [{ "id": "custom.lineWidth", "value": 3 },
                           { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          { "matcher": { "id": "byName", "options": "P999" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "placement": "bottom", "displayMode": "table" }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "🔥 Throughput — Requests Per Second",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(recommendation_requests_total[1m]))",
          "legendFormat": "Total RPS"
        },
        {
          "expr": "sum(rate(recommendation_requests_total{status='success'}[1m]))",
          "legendFormat": "Success RPS"
        },
        {
          "expr": "sum(rate(recommendation_fallback_total[1m]))",
          "legendFormat": "Fallback RPS"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Fallback RPS" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "🏗️ Pipeline Stage Latencies (P99)",
      "description": "Breakdown of Stage-1 ANN, Stage-2 ONNX, and feature fetch latencies.",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(stage1_latency_ms_bucket[2m])) by (le))",
          "legendFormat": "Stage-1 ANN (Qdrant)"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(stage2_latency_ms_bucket[2m])) by (le))",
          "legendFormat": "Stage-2 ONNX"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(feature_fetch_latency_ms_bucket[2m])) by (le))",
          "legendFormat": "Feature Fetch (Redis)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "placement": "bottom", "displayMode": "table",
                    "calcs": ["mean", "p99"] }
      }
    },
    {
      "id": 21,
      "type": "heatmap",
      "title": "🌡️ Latency Distribution Heatmap",
      "description": "Full latency distribution — identifies bimodal patterns (cache hits vs misses).",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum(rate(recommendation_latency_ms_bucket[5m])) by (le)",
        "legendFormat": "{{le}}",
        "format": "heatmap"
      }],
      "options": {
        "calculate": false,
        "color": { "scheme": "Spectral", "fill": "dark-orange" },
        "yAxis": { "unit": "ms", "decimals": 0 }
      }
    },
    {
      "id": 30,
      "type": "table",
      "title": "⚠️ Active Alerts",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "targets": [{
        "expr": "ALERTS{alertstate='firing', team='recommendations'}",
        "legendFormat": "{{alertname}}"
      }],
      "transformations": [
        { "id": "organize", "options": {
          "renameByName": { "alertname": "Alert", "severity": "Severity", "Value": "Value" }
        }}
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "🛡️ Safety Filter Activity",
      "description": "Number of items removed per request by safety rule. Spikes indicate content catalogue issues.",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(safety_filter_sodium_total[5m]))",
          "legendFormat": "Sodium (HTN)"
        },
        {
          "expr": "sum(rate(safety_filter_intensity_total[5m]))",
          "legendFormat": "Intensity (Cardiac)"
        },
        {
          "expr": "sum(rate(safety_filter_carbs_total[5m]))",
          "legendFormat": "Carbs (Diabetes)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    }
  ]
}
