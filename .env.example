# ══════════════════════════════════════════════════════════════════
# FITNESS REC ENGINE — Environment Configuration Template
# Copy to .env and fill in your values. Never commit .env to git.
# ══════════════════════════════════════════════════════════════════

# ── Runtime ───────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
SERVICE_NAME=fitness-rec-engine

# ── Security ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_64_char_hex_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── PostgreSQL (NeonDB) ───────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host/db?ssl=require
DATABASE_URL=postgresql+asyncpg://neondb_owner:npg_JqDQtgWVE3C2@ep-young-frost-aq03fhnr.c-8.us-east-1.aws.neon.tech/neondb?ssl=require
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_FEATURE_TTL_SECONDS=300

# ── Qdrant ────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# QDRANT_API_KEY=your_qdrant_cloud_api_key   # only for Qdrant Cloud
QDRANT_COLLECTION_NAME=fitness_content
QDRANT_TOP_K=100
HNSW_M=16
HNSW_EF_CONSTRUCT=200
HNSW_EF_SEARCH=128

# ── Kafka ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TELEMETRY_TOPIC=fitness.telemetry.realtime
KAFKA_INTERACTION_TOPIC=fitness.user.interactions

# ── Embedding Model ───────────────────────────────────────────────
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=256
EMBEDDING_DEVICE=cpu   # set to "cuda" for GPU deployment

# ── ONNX Ranking Model ────────────────────────────────────────────
ONNX_MODEL_PATH=artifacts/ranking_model.onnx
ONNX_INTRA_OP_THREADS=4
ONNX_INTER_OP_THREADS=2

# ── Safety Thresholds ─────────────────────────────────────────────
MAX_SODIUM_HYPERTENSIVE_MG=400.0
MAX_INTENSITY_CARDIAC_RISK=0.7
MIN_CONFIDENCE_THRESHOLD=0.05

# ── Performance SLA ───────────────────────────────────────────────
RECOMMENDATION_TIMEOUT_MS=28.0
STAGE1_TIMEOUT_MS=10.0
STAGE2_TIMEOUT_MS=15.0
